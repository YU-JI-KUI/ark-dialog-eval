# ============ Judge 后端选择 ============
# mock   = 内置规则桩,无需任何模型即可端到端跑通(默认,本地演示用这个)
# pingan = 平安内网大模型(需配齐下面的平安变量,变量不全会自动降级回 mock)
JUDGE_BACKEND=mock
JUDGE_CONCURRENCY=4

# ============ 平安大模型平台(双签名鉴权,OpenAI 接口)============
# 来源:科技网关 + 应用申请。变量名与 ark_navigator 保持一致,便于内网复用同一套凭据。
OPEN_AI_URL=http://eagw-gateway-sf.paic.com.cn:80/pingan/bigModel/api/v1/chat/completions
RSA_PK=your_rsa_private_key_hex
CRE_ID=your_cre_id
OPEN_API_CODE=your_open_api_code
LLM_APP_KEY=your_llm_app_key
LLM_APP_SECRET=your_llm_app_secret
LLM_SCENE_ID=your_llm_scene_id
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
